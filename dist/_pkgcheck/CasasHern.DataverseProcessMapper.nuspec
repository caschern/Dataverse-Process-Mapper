<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>CasasHern.DataverseProcessMapper</id>
    <version>1.0.6</version>
    <title>Dataverse Process Mapper</title>
    <authors>Cristian Casas</authors>
    <owners>Cristian Casas</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <projectUrl>https://github.com/caschern/Dataverse-Process-Mapper</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/caschern/Dataverse-Process-Mapper/main/images/icon.png</iconUrl>
    <description>List Classic Workflows and Power Automate flows from the Dataverse workflow table and render visual process maps (XAML for workflows, JSON for flows), exportable to PDF or HTML.</description>
    <releaseNotes>1.0.4: Place assemblies in lib/net48/Plugins as the Tool Library requires. 1.0.3: Use the XrmToolBox dependency id the portal expects. 1.0.2: Declare XrmToolBox dependency required by the portal. 1.0.1: Add public iconUrl for the XrmToolBox portal logo. 1.0.0: Initial release — two-tab UI for Power Automate flows and classic workflows, GDI+ process maps, PDF and HTML export.</releaseNotes>
    <copyright>Copyright (c) Cristian Casas</copyright>
    <tags>XrmToolBox Dataverse Dynamics365 PowerAutomate Workflow ProcessMap Diagram</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
  </metadata>
</package>